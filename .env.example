# ================================================
# LAMBOM WHEEL - Environment Variables Template
# ================================================
# Copy file này thành .env và điền các giá trị thực tế vào.

# [BẮT BUỘC] Gemini AI API Key - Dùng cho gợi ý món ăn theo thời tiết và chatbot tư vấn
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# [TÙY CHỌN] SerpApi Key - Dùng cho tính năng Tìm kiếm quán ăn gần đây qua Google Maps
# Lấy tại: https://serpapi.com
SERPAPI_API_KEY="your_serpapi_key_here"

# [BẮT BUỘC khi deploy] MongoDB Atlas Connection String - Lưu trữ dữ liệu quán ăn vĩnh viễn trên cloud
# Tạo cluster miễn phí tại: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/lambom-wheel?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/lambom-wheel?retryWrites=true&w=majority&appName=Cluster0"
